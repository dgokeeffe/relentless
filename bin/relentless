#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "claude-agent-sdk>=0.1.37",
# ]
# ///
"""relentless — auto-continuing Claude Code agent with real-time loop detection

Uses the Claude Agent SDK for direct tool-call visibility, native loop detection,
graceful interrupt, and cost tracking — while retaining access to ALL Claude Code
tools, skills, and MCP servers.

Usage:
  relentless "Refactor the auth module to use JWT tokens"
  relentless -f task.md
  relentless -n 8 -m opus "Build the feature described in PRD.md"
  echo "Fix all lint errors" | relentless

Options:
  -n NUM     Max sessions (default: 5)
  -b USD     Max budget per session in USD (default: no limit)
  -m MODEL   Model to use (default: system default)
  -d DIR     Working directory (default: current)
  -f FILE    Read task description from file
  -p MODE    Permission mode: default, acceptEdits, plan, auto, bypassPermissions (default: auto)
  -s FILE    State file path (default: ./_relentless_state.md)
  -t MINS    Timeout per session in minutes (default: 30)
  -v         Verbose — show all tool calls and messages
  -c         Continue from existing state file
  --dry-run  Print the prompt that would be sent without running
  --max-turns N       Max assistant turns per session before handoff (default: 50)
  --context-chars N   Estimated char budget per session (default: 480000)
  --handoff-file FILE JSON handoff path (default: alongside state file)
  --handoff-max-bytes N  Max handoff JSON bytes (default: 8192)
  --failure-repeat-limit N  Same failing tool-result signature N times → loop
  --adaptive/--no-adaptive  Enable/disable adaptive tuning from run history
  --adaptive-profile MODE   conservative | balanced | aggressive (default: balanced)
  --self-test        Run internal detector/tuning self-tests and exit
  --no-checkpoint     Skip checkpoint micro-session on context handoff
"""

import argparse
import asyncio
import hashlib
import json
import logging
import os
import re
import shutil
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path

from claude_agent_sdk import (
    AssistantMessage,
    ClaudeAgentOptions,
    ResultMessage,
    UserMessage,
    query,
)
from claude_agent_sdk.types import TextBlock, ToolUseBlock

# ── Constants ──────────────────────────────────────────────────

STUCK_THRESHOLD = 2        # escalate after N sessions with identical state hash
TOOL_REPEAT_LIMIT = 3      # same (tool, input_hash) N times in one session → loop
SESSION_STALL_SECS = 300   # 5 min with no messages → stall
MAX_TOOL_CALLS_PER_SESSION = 200  # safety cap per session
FAILURE_REPEAT_LIMIT = 3          # same failing tool-result signature N times → loop
DEFAULT_MAX_TURNS = 50            # assistant turns per session before handoff
DEFAULT_CONTEXT_CHARS = 480_000   # ~120K tokens at ~4 chars/token
CONTEXT_SOFT_PCT = 0.75           # log warning (fraction of budget)
CONTEXT_HARD_PCT = 0.90           # force graceful handoff (fraction of budget)
ADAPTIVE_HISTORY_LOOKBACK = 5
RUN_HISTORY_FILENAME = "run_history.jsonl"
RUN_JOURNAL_FILENAME = "run_journal.jsonl"
MODEL_USAGE_FILENAME = "model_usage.json"
ADAPTIVE_PROFILE_DEFAULT = "balanced"
DEFAULT_HANDOFF_FILENAME = "_relentless_handoff.json"
HANDOFF_SCHEMA_VERSION = "1.0"
HANDOFF_MAX_BYTES = 8_192
HANDOFF_LIST_LIMIT = 8
HANDOFF_TEXT_LIMIT = 220
HANDOFF_SUMMARY_LIMIT = 900
