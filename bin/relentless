FAILURE_MARKERS = (
    "error",
    "exception",
    "traceback",
    "failed",
    "[exit code",
    "timeout",
    "permissiondenied",
)

log = logging.getLogger("relentless")


# ── Logging Setup ──────────────────────────────────────────────

def setup_logging(log_dir: Path, verbose: bool) -> Path:
    log_dir.mkdir(exist_ok=True)

    console = logging.StreamHandler()
    console.setLevel(logging.INFO if verbose else logging.WARNING)
    console.setFormatter(logging.Formatter("%(message)s"))

    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    master_log = log_dir / f"relentless_{ts}.log"
    fh = logging.FileHandler(master_log)
    fh.setLevel(logging.DEBUG)
    fh.setFormatter(
        logging.Formatter("%(asctime)s [%(levelname)s] %(message)s", datefmt="%Y-%m-%dT%H:%M:%S")
    )

    log.setLevel(logging.DEBUG)
    log.addHandler(console)
    log.addHandler(fh)
    return master_log


# ── State Hash Tracking (cross-session loop guard) ────────────

class StateTracker:
    """Detect agent loops by hashing state file content across sessions."""

    def __init__(self, state_file: Path, stuck_threshold: int = STUCK_THRESHOLD):
        self.state_file = state_file
        self.stuck_threshold = stuck_threshold
        self.hashes: list[tuple[int, str]] = []  # (session_num, hash)

    def compute_hash(self) -> str:
        if not self.state_file.exists():
            return "no_state_file"
        content = self.state_file.read_text()
        lines = [line.strip() for line in content.splitlines() if line.strip()]
        return hashlib.md5("\n".join(lines).encode()).hexdigest()

    def record(self, session_num: int) -> str:
        h = self.compute_hash()
        self.hashes.append((session_num, h))
        log.debug(f"State hash after session {session_num}: {h}")
        return h

    def is_stuck(self) -> tuple[bool, str]:
        if len(self.hashes) < self.stuck_threshold:
            return False, ""
        recent = [h for _, h in self.hashes[-self.stuck_threshold:]]
        if len(set(recent)) == 1 and recent[0] != "no_state_file":
            sessions = [s for s, _ in self.hashes[-self.stuck_threshold:]]
            msg = (
                f"Identical state across sessions {sessions} "
                f"(hash: {recent[0][:12]}...). Agent is repeating without progress."
            )
            return True, msg
        return False, ""


# ── Intra-session Tool Loop Detector ──────────────────────────

class ToolLoopDetector:
    """Track (tool_name, hash(input)) pairs within a session to detect loops."""

    def __init__(self, repeat_limit: int = TOOL_REPEAT_LIMIT, exempt_paths: set[str] | None = None):
        self.repeat_limit = repeat_limit
        self.exempt_paths = exempt_paths or set()
        self.calls: dict[str, int] = {}  # "tool:input_hash" → count
        self.audit_trail: list[dict] = []
        self.total_calls = 0

    def _is_exempt(self, tool_name: str, tool_input: dict) -> bool:
        """Exempt writes to state/handoff files from loop detection."""
        if not self.exempt_paths:
            return False
        if tool_name not in ("Write", "Edit"):
            return False
        target = tool_input.get("file_path", "")
        return any(target.endswith(p) or target == p for p in self.exempt_paths)

    def record(self, tool_name: str, tool_input: dict) -> tuple[bool, str]:
        """Record a tool call. Returns (is_loop, description)."""
        self.total_calls += 1
        input_hash = hashlib.md5(
            json.dumps(tool_input, sort_keys=True, default=str).encode()
        ).hexdigest()[:12]
        key = f"{tool_name}:{input_hash}"

        self.calls[key] = self.calls.get(key, 0) + 1
        count = self.calls[key]

        self.audit_trail.append({
            "seq": self.total_calls,
            "tool": tool_name,
            "input_hash": input_hash,
            "repeat_count": count,
            "exempt": self._is_exempt(tool_name, tool_input),
            "timestamp": datetime.now(timezone.utc).isoformat(),
        })

        if self._is_exempt(tool_name, tool_input):
            return False, ""

        if count >= self.repeat_limit:
            desc = (
                f"Tool '{tool_name}' called {count} times with same input "
                f"(hash: {input_hash})"
            )
            return True, desc
        return False, ""


# ── Context Budget Tracker (graceful handoff) ────────────────

class ContextBudget:
    """Track estimated context consumption for graceful session handoff.

    Uses two heuristics (whichever triggers first):
    1. Turn count — each AssistantMessage is one turn; predictable context cost
    2. Character accumulation — catches cases where few turns carry huge payloads
       (e.g. large file reads in tool results)

    At CONTEXT_SOFT_PCT, logs a warning.
    At CONTEXT_HARD_PCT, signals the session to stop so the outer loop can
    hand off to a fresh session with the state file.
    """

    def __init__(
        self,
        max_turns: int = DEFAULT_MAX_TURNS,
        max_chars: int = DEFAULT_CONTEXT_CHARS,
        soft_pct: float = CONTEXT_SOFT_PCT,
        hard_pct: float = CONTEXT_HARD_PCT,
    ):
        self.max_turns = max_turns
        self.max_chars = max_chars
        self.soft_pct = soft_pct
        self.hard_pct = hard_pct
        self.turn_count = 0
        self.char_count = 0
        self._soft_warned = False

    def record_message(self, message) -> None:
        """Accumulate estimated token cost from a streamed message."""
        if isinstance(message, AssistantMessage):
            self.turn_count += 1
            for block in message.content:
                if isinstance(block, TextBlock):
                    self.char_count += len(block.text)
                elif isinstance(block, ToolUseBlock):
                    self.char_count += len(json.dumps(block.input, default=str))
        elif isinstance(message, UserMessage):
            # Tool results can be enormous (file reads, search results).
            # Serialize defensively — SDK versions may differ.
            try:
                self.char_count += len(str(message.content))
            except Exception:
                pass

    @property
    def utilization(self) -> float:
        """Max of turn-based and char-based utilization (0.0 – 1.0+)."""
        turn_pct = self.turn_count / self.max_turns if self.max_turns > 0 else 0
        char_pct = self.char_count / self.max_chars if self.max_chars > 0 else 0
        return max(turn_pct, char_pct)

    def should_warn(self) -> bool:
        if self._soft_warned:
            return False
        if self.utilization >= self.soft_pct:
            self._soft_warned = True
            return True
        return False

    def should_stop(self) -> bool:
        return self.utilization >= self.hard_pct

    def status(self) -> str:
        turn_pct = (self.turn_count / self.max_turns * 100) if self.max_turns else 0
        char_pct = (self.char_count / self.max_chars * 100) if self.max_chars else 0
        return (
            f"turns={self.turn_count}/{self.max_turns} ({turn_pct:.0f}%) "
            f"chars≈{self.char_count:,}/{self.max_chars:,} ({char_pct:.0f}%)"
        )


# ── Repeated Failure Signature Detector ────────────────────────

class FailureSignatureDetector:
    """Detect repeated failing tool-result signatures within a session."""

    def __init__(self, repeat_limit: int = FAILURE_REPEAT_LIMIT):
        self.repeat_limit = repeat_limit
        self.last_signature = ""
        self.consecutive = 0

    def _extract_signature(self, text: str) -> str:
        lines: list[str] = []
        for raw in text.splitlines():
            line = raw.strip()
            if not line:
                continue
            lowered = line.lower()
            if any(marker in lowered for marker in FAILURE_MARKERS):
                lines.append(line[:220])
            if len(lines) >= 3:
                break
        return " | ".join(lines)

    def record(self, text: str) -> tuple[bool, str]:
        signature = self._extract_signature(text)
        if not signature:
            self.last_signature = ""
            self.consecutive = 0
            return False, ""

        if signature == self.last_signature:
            self.consecutive += 1
        else:
            self.last_signature = signature
            self.consecutive = 1

        if self.consecutive >= self.repeat_limit:
            return True, f"Repeated failing tool result {self.consecutive}x: {signature[:180]}"
        return False, ""


# ── Adaptive Memory and Tuning ─────────────────────────────────

def _flag_used(cli_args: list[str], flag: str) -> bool:
    return any(arg == flag or arg.startswith(f"{flag}=") for arg in cli_args)


def compute_task_hash(task: str) -> str:
    return hashlib.sha256(task.encode("utf-8")).hexdigest()[:16]


def _adaptive_profile_config(profile: str) -> dict[str, int]:
    return ADAPTIVE_PROFILES.get(profile, ADAPTIVE_PROFILES[ADAPTIVE_PROFILE_DEFAULT])


def load_recent_run_history(log_dir: Path, task_hash: str, limit: int = ADAPTIVE_HISTORY_LOOKBACK) -> list[dict]:
    history_path = log_dir / RUN_HISTORY_FILENAME
    if not history_path.exists():
        return []

    records: list[dict] = []
    try:
        for line in reversed(history_path.read_text().splitlines()):
            if not line.strip():
                continue
            payload = json.loads(line)
            if not isinstance(payload, dict):
                continue
            if payload.get("task_hash") != task_hash:
                continue
            records.append(payload)
            if len(records) >= limit:
                break
    except Exception:
        log.debug("Failed reading adaptive run history", exc_info=True)
    return records


def append_run_history(log_dir: Path, payload: dict) -> None:
    history_path = log_dir / RUN_HISTORY_FILENAME
    try:
        with history_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(payload, sort_keys=True) + "\n")
    except Exception:
        log.debug("Failed writing adaptive run history", exc_info=True)


def load_last_success_model(log_dir: Path) -> str:
    model_path = log_dir / MODEL_USAGE_FILENAME
    if not model_path.exists():
        return ""
    try:
        payload = json.loads(model_path.read_text())
    except Exception:
        log.debug("Failed reading model memory file", exc_info=True)
        return ""
    if isinstance(payload, dict):
        model = payload.get("last_success_model")
        if isinstance(model, str):
            return model
    return ""


def save_last_success_model(log_dir: Path, model_name: str) -> None:
    if not model_name:
        return

    model_path = log_dir / MODEL_USAGE_FILENAME
    payload: dict = {}
    if model_path.exists():
        try:
            existing = json.loads(model_path.read_text())
            if isinstance(existing, dict):
                payload = existing
        except Exception:
            log.debug("Failed parsing model memory file", exc_info=True)

    counts = payload.get("success_model_counts", {})
    if not isinstance(counts, dict):
        counts = {}
    counts[model_name] = int(counts.get(model_name, 0)) + 1

    payload["last_success_model"] = model_name
    payload["success_model_counts"] = counts
    payload["updated_at"] = datetime.now(timezone.utc).isoformat()

    try:
        model_path.write_text(json.dumps(payload, indent=2))
    except Exception:
        log.debug("Failed writing model memory file", exc_info=True)


def apply_adaptive_overrides(
    args: argparse.Namespace,
    log_dir: Path,
    task_hash: str,
    cli_args: list[str],
    profile: str,
) -> list[str]:
    notes: list[str] = []
    cfg = _adaptive_profile_config(profile)
    history = load_recent_run_history(log_dir, task_hash, limit=ADAPTIVE_HISTORY_LOOKBACK)
    if not history:
        return notes

    if not args.m and not _flag_used(cli_args, "-m"):
        remembered_model = load_last_success_model(log_dir)
        if remembered_model:
            args.m = remembered_model
            notes.append(f"model= {remembered_model} (from last successful run)")

    failed_runs = [r for r in history if int(r.get("exit_code", 1)) != 0]
    if len(failed_runs) < int(cfg["min_failed_runs"]):
        return notes

    recent_failures = failed_runs[:2]

    if (
        not _flag_used(cli_args, "-n")
        and all(
            str(r.get("final_reason", "")) in ("max_sessions", "max_sessions_exhausted")
            for r in recent_failures
        )
    ):
        old = args.n
        args.n = min(args.n + int(cfg["sessions_bump"]), int(cfg["max_sessions_cap"]))
        if args.n != old:
            notes.append(f"sessions= {old}->{args.n} (recent runs exhausted max sessions)")

    loop_events = 0
    stall_events = 0
    context_events = 0
    for run in failed_runs[:3]:
        counts = run.get("stop_reason_counts", {})
        if not isinstance(counts, dict):
            continue
        loop_events += int(counts.get("loop_detected", 0))
        stall_events += int(counts.get("stall", 0))
        context_events += int(counts.get("context_limit", 0))

    if loop_events >= int(cfg["loop_events_threshold"]):
        if not _flag_used(cli_args, "--tool-repeat-limit"):
            old = args.tool_repeat_limit
            args.tool_repeat_limit = min(
                args.tool_repeat_limit + int(cfg["tool_repeat_bump"]),
                int(cfg["tool_repeat_cap"]),
            )
            if args.tool_repeat_limit != old:
                notes.append(
                    f"tool_repeat_limit= {old}->{args.tool_repeat_limit} "
                    "(recent loop detections)"
                )
        if not _flag_used(cli_args, "--max-tool-calls"):
            old = args.max_tool_calls
            args.max_tool_calls = min(
                args.max_tool_calls + int(cfg["max_tool_calls_bump"]),
                int(cfg["max_tool_calls_cap"]),
            )
            if args.max_tool_calls != old:
                notes.append(
                    f"max_tool_calls= {old}->{args.max_tool_calls} "
                    "(recent loop detections)"
                )

    if stall_events >= int(cfg["stall_events_threshold"]) and not _flag_used(cli_args, "-t"):
        old = args.t
        args.t = min(args.t + int(cfg["timeout_bump"]), int(cfg["timeout_cap"]))
        if args.t != old:
            notes.append(f"timeout= {old}m->{args.t}m (recent stalled sessions)")

    if context_events >= int(cfg["context_events_threshold"]) and not _flag_used(cli_args, "--max-turns"):
        old = args.max_turns
        args.max_turns = min(args.max_turns + int(cfg["max_turns_bump"]), int(cfg["max_turns_cap"]))
        if args.max_turns != old:
            notes.append(
                f"max_turns= {old}->{args.max_turns} (frequent context handoffs)"
            )

    return notes


# ── Handoff Contract + Session Journal ─────────────────────────

def append_run_journal(log_dir: Path, payload: dict) -> None:
    journal_path = log_dir / RUN_JOURNAL_FILENAME
    try:
        with journal_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(payload, sort_keys=True) + "\n")
    except Exception:
        log.debug("Failed writing run journal", exc_info=True)


def default_handoff_file_for_state(state_file: Path) -> Path:
    return state_file.with_name(DEFAULT_HANDOFF_FILENAME)


def _trim_text(value: object, limit: int = HANDOFF_TEXT_LIMIT) -> str:
    text = str(value or "").strip()
    if len(text) <= limit:
        return text
    return text[: max(0, limit - 3)].rstrip() + "..."


def _trim_items(value: object, list_limit: int = HANDOFF_LIST_LIMIT, text_limit: int = HANDOFF_TEXT_LIMIT) -> list[str]:
    if not isinstance(value, list):
        return []
    items: list[str] = []
    for raw in value:
        t = _trim_text(raw, text_limit)
        if t:
            items.append(t)
        if len(items) >= list_limit:
            break
    return items


def extract_acceptance_criteria(task: str) -> list[str]:
    out: list[str] = []
    seen: set[str] = set()
    for match in re.finditer(r"\bAC-\d+\b", task, flags=re.IGNORECASE):
        ac = match.group(0).upper()
        if ac not in seen:
            seen.add(ac)
            out.append(ac)
    return out


def _clean_state_line(line: str) -> str:
    cleaned = line.strip()
    cleaned = re.sub(r"^[-*]\s+", "", cleaned)
    return cleaned.strip()


def parse_state_sections(state_text: str) -> dict[str, object]:
    sections: dict[str, object] = {
        "status": "",
        "completed": [],
        "in_progress": [],
        "discoveries": [],
        "remaining": [],
        "blockers": [],
    }

    current: str | None = None
    heading_map = {
        "completed": "completed",
        "in progress": "in_progress",
        "discoveries": "discoveries",
        "remaining": "remaining",
        "blockers": "blockers",
    }
    for raw in state_text.splitlines():
        line = raw.strip()
        if not line:
            continue
        upper = line.upper()
        if upper.startswith("STATUS:"):
            sections["status"] = line.split(":", 1)[1].strip().upper()
            continue
        if line.startswith("## "):
            key = heading_map.get(line[3:].strip().lower())
            current = key
            continue
        if current:
            cleaned = _clean_state_line(line)
            if cleaned:
                casted = sections.get(current)
                if isinstance(casted, list):
                    casted.append(cleaned)
    return sections


def _remaining_acs_from_done(ac_ids: list[str], done_items: list[str]) -> list[str]:
    if not ac_ids:
        return []
    done_blob = "\n".join(done_items).upper()
    return [ac for ac in ac_ids if ac not in done_blob]


def _enforce_handoff_size(payload: dict, max_bytes: int) -> dict:
    cap = max(1024, max_bytes)
    while len(json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8")) > cap:
        trimmed = False
        for key in ("artifact_refs", "discoveries", "done", "blockers", "remaining_acs"):
            values = payload.get(key)
            if isinstance(values, list) and len(values) > 1:
                values.pop()
                trimmed = True
                break
        if trimmed:
            continue
        for key in ("summary", "next_step", "in_flight"):
            value = str(payload.get(key, ""))
            if len(value) > 120:
                payload[key] = value[:117].rstrip() + "..."
                trimmed = True
                break
        if not trimmed:
            payload["summary"] = _trim_text(payload.get("summary", ""), 120)
            break
    return payload


def normalize_handoff_payload(
    payload: object,
    *,
    task: str,
    session_num: int,
    ac_ids: list[str],
    max_bytes: int,
) -> dict:
    data = payload if isinstance(payload, dict) else {}

    done = _trim_items(data.get("done"), list_limit=HANDOFF_LIST_LIMIT)
    discoveries = _trim_items(data.get("discoveries"), list_limit=HANDOFF_LIST_LIMIT)
    blockers = _trim_items(data.get("blockers"), list_limit=HANDOFF_LIST_LIMIT)
    artifact_refs = _trim_items(data.get("artifact_refs"), list_limit=HANDOFF_LIST_LIMIT)

    in_flight = _trim_text(data.get("in_flight"), HANDOFF_TEXT_LIMIT)
    next_step = _trim_text(data.get("next_step"), HANDOFF_TEXT_LIMIT)
    summary = _trim_text(data.get("summary"), HANDOFF_SUMMARY_LIMIT)

    success = bool(data.get("success", False))
    is_continue = bool(data.get("is_continue", not success))
    if success:
        is_continue = False

    goal_default = _trim_text(next((ln.strip() for ln in task.splitlines() if ln.strip()), "Complete the requested task."), HANDOFF_TEXT_LIMIT)
    goal = _trim_text(data.get("goal") or goal_default, HANDOFF_TEXT_LIMIT)

    if not summary:
        if success:
            summary = "Completed required work and marked run successful."
        elif next_step:
            summary = f"Continue with next step: {next_step}"
        elif in_flight:
            summary = f"In progress: {in_flight}"
        else:
            summary = "Continue implementation using state and remaining acceptance criteria."

    remaining_acs = _trim_items(data.get("remaining_acs"), list_limit=HANDOFF_LIST_LIMIT)
    if not remaining_acs:
        remaining_acs = _remaining_acs_from_done(ac_ids, done)
    if ac_ids:
        allowed = {ac.upper() for ac in ac_ids}
        remaining_acs = [ac for ac in remaining_acs if ac.upper() in allowed]
        if not remaining_acs:
            remaining_acs = _remaining_acs_from_done(ac_ids, done)

    target_ac = _trim_text(data.get("target_ac"), 32).upper()
    if ac_ids:
        allowed = {ac.upper() for ac in ac_ids}
        if target_ac not in allowed:
            target_ac = remaining_acs[0] if remaining_acs else ac_ids[0]

    normalized = {
        "schema_version": HANDOFF_SCHEMA_VERSION,
        "session": int(data.get("session") or session_num),
        "goal": goal,
        "success": bool(success),
        "is_continue": bool(is_continue),
        "summary": summary,
        "done": done,
        "in_flight": in_flight,
        "next_step": next_step,
        "discoveries": discoveries,
        "blockers": blockers,
        "artifact_refs": artifact_refs,
        "target_ac": target_ac,
        "remaining_acs": remaining_acs,
        "updated_at": datetime.now(timezone.utc).isoformat(),
    }
    return _enforce_handoff_size(normalized, max_bytes=max_bytes)


def validate_handoff_payload(payload: object, max_bytes: int) -> tuple[bool, str]:
    if not isinstance(payload, dict):
        return False, "handoff payload must be a JSON object"

    required_bool = ("success", "is_continue")
    required_str = ("goal", "summary", "in_flight", "next_step")
    required_list = ("done", "discoveries", "blockers", "artifact_refs", "remaining_acs")

    for key in required_bool:
        if not isinstance(payload.get(key), bool):
            return False, f"handoff.{key} must be boolean"
    for key in required_str:
        if not isinstance(payload.get(key), str):
            return False, f"handoff.{key} must be string"
    for key in required_list:
        value = payload.get(key)
        if not isinstance(value, list) or any(not isinstance(v, str) for v in value):
            return False, f"handoff.{key} must be list[str]"

    if payload.get("success") and payload.get("is_continue"):
        return False, "handoff success=true requires is_continue=false"
    if not payload.get("summary", "").strip():
        return False, "handoff.summary cannot be empty"

    encoded_size = len(json.dumps(payload, ensure_ascii=True, separators=(",", ":")).encode("utf-8"))
    if encoded_size > max(1024, max_bytes):
        return False, f"handoff exceeds size cap ({encoded_size} bytes)"
    return True, ""


def read_handoff_payload(handoff_file: Path, max_bytes: int) -> tuple[dict | None, str]:
    if not handoff_file.exists():
        return None, "handoff file missing"
    try:
        payload = json.loads(handoff_file.read_text())
    except Exception as exc:
        return None, f"failed to parse handoff JSON: {exc}"

    ok, reason = validate_handoff_payload(payload, max_bytes=max_bytes)
    if not ok:
        return None, reason
    return payload, ""


def write_handoff_payload(handoff_file: Path, payload: object, *, task: str, session_num: int, ac_ids: list[str], max_bytes: int) -> dict:
    normalized = normalize_handoff_payload(
        payload,
        task=task,
        session_num=session_num,
        ac_ids=ac_ids,
        max_bytes=max_bytes,
    )
    handoff_file.write_text(json.dumps(normalized, indent=2) + "\n")
    return normalized


def fallback_handoff_from_state(
    *,
    task: str,
    state_file: Path,
    handoff_file: Path,
    session_num: int,
    ac_ids: list[str],
    max_bytes: int,
    reason: str,
) -> dict:
    state_text = state_file.read_text() if state_file.exists() else ""
    sections = parse_state_sections(state_text)
    status = str(sections.get("status", ""))
    completed = sections.get("completed", []) if isinstance(sections.get("completed"), list) else []
    in_progress = sections.get("in_progress", []) if isinstance(sections.get("in_progress"), list) else []
    discoveries = sections.get("discoveries", []) if isinstance(sections.get("discoveries"), list) else []
    remaining = sections.get("remaining", []) if isinstance(sections.get("remaining"), list) else []
    blockers = sections.get("blockers", []) if isinstance(sections.get("blockers"), list) else []

    success = status == "COMPLETE"
    next_step = remaining[0] if remaining else ""
    in_flight = in_progress[0] if in_progress else ""
    summary = f"{reason}. {'Complete' if success else 'Continue'} from state + handoff protocol."
    payload = {
        "schema_version": HANDOFF_SCHEMA_VERSION,
        "session": session_num,
        "goal": next((ln.strip() for ln in task.splitlines() if ln.strip()), "Complete the requested task."),
        "success": success,
        "is_continue": not success,
        "summary": summary,
        "done": completed,
        "in_flight": in_flight,
        "next_step": next_step,
        "discoveries": discoveries,
        "blockers": blockers,
        "artifact_refs": [],
        "target_ac": "",
        "remaining_acs": [],
    }
    return write_handoff_payload(
        handoff_file,
        payload,
        task=task,
        session_num=session_num,
        ac_ids=ac_ids,
        max_bytes=max_bytes,
    )


def summarize_handoff_for_prompt(payload: dict | None) -> str:
    if not payload:
        return "(no prior handoff found)"
    parts = []
    target = str(payload.get("target_ac", "")).strip()
    if target:
        parts.append(f"target_ac={target}")
    summary = _trim_text(payload.get("summary", ""), 180)
    if summary:
        parts.append(f"summary={summary}")
    next_step = _trim_text(payload.get("next_step", ""), 140)
    if next_step:
        parts.append(f"next_step={next_step}")
    remaining_acs = payload.get("remaining_acs", [])
    if isinstance(remaining_acs, list) and remaining_acs:
        parts.append(f"remaining_acs={', '.join(remaining_acs[:4])}")
    return " | ".join(parts) if parts else "(handoff exists but is sparse)"


# ── Self-Test Harness ──────────────────────────────────────────

def _make_test_args() -> argparse.Namespace:
    return argparse.Namespace(
        m="",
        n=5,
        tool_repeat_limit=3,
        max_tool_calls=200,
        t=30,
        max_turns=50,
        handoff_max_bytes=HANDOFF_MAX_BYTES,
    )


def _test_tool_loop_detector_exempt_paths() -> None:
    """Writes to state/handoff files should not trigger loop detection."""
    detector = ToolLoopDetector(repeat_limit=3, exempt_paths={"/tmp/state.md", "/tmp/handoff.json"})

    # Non-exempt Write should trigger after 3
    for _ in range(2):
        loop, _ = detector.record("Write", {"file_path": "/tmp/other.txt", "content": "x"})
        assert not loop
    loop, _ = detector.record("Write", {"file_path": "/tmp/other.txt", "content": "x"})
    assert loop

    # Exempt state file Write should never trigger
    detector2 = ToolLoopDetector(repeat_limit=3, exempt_paths={"/tmp/state.md", "/tmp/handoff.json"})
    for _ in range(5):
        loop, _ = detector2.record("Write", {"file_path": "/tmp/state.md", "content": "STATUS: IN_PROGRESS"})
        assert not loop

    # Exempt handoff file Write should never trigger
    for _ in range(5):
        loop, _ = detector2.record("Write", {"file_path": "/tmp/handoff.json", "content": "{}"})
        assert not loop

    # Non-Write tools to exempt paths should still trigger
    detector3 = ToolLoopDetector(repeat_limit=3, exempt_paths={"/tmp/state.md"})
    for _ in range(2):
        loop, _ = detector3.record("Read", {"file_path": "/tmp/state.md"})
        assert not loop
    loop, _ = detector3.record("Read", {"file_path": "/tmp/state.md"})
    assert loop


def _test_failure_signature_detector_loop() -> None:
    detector = FailureSignatureDetector(repeat_limit=2)
    loop, _ = detector.record("Error: database unavailable")
    assert not loop
    loop, desc = detector.record("Error: database unavailable")
    assert loop
    assert "Repeated failing tool result" in desc


def _test_failure_signature_detector_reset() -> None:
    detector = FailureSignatureDetector(repeat_limit=2)
    loop, _ = detector.record("Error: timeout")
    assert not loop
    loop, _ = detector.record("all good")
    assert not loop
    loop, _ = detector.record("Error: timeout")
    assert not loop


def _test_adaptive_tuning_profile_and_flags() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        log_dir = Path(temp_dir)
        task_hash = "abc123def4567890"

        save_last_success_model(log_dir, "claude-sonnet")
        for _ in range(2):
            append_run_history(
                log_dir,
                {
                    "timestamp": datetime.now(timezone.utc).isoformat(),
                    "task_hash": task_hash,
                    "exit_code": 1,
                    "final_reason": "max_sessions_exhausted",
                    "stop_reason_counts": {
                        "loop_detected": 2,
                        "stall": 1,
                        "context_limit": 3,
                    },
                },
            )

        args = _make_test_args()
        apply_adaptive_overrides(
            args=args,
            log_dir=log_dir,
            task_hash=task_hash,
            cli_args=[],
            profile="aggressive",
        )
        assert args.m == "claude-sonnet"
        assert args.n > 5
        assert args.max_tool_calls > 200
        assert args.max_turns > 50

        args_with_n_flag = _make_test_args()
        apply_adaptive_overrides(
            args=args_with_n_flag,
            log_dir=log_dir,
            task_hash=task_hash,
            cli_args=["-n", "9"],
            profile="aggressive",
        )
        assert args_with_n_flag.n == 5


def _test_handoff_normalization_enforces_size_and_schema() -> None:
    huge = "x" * 10_000
    task = "Implement AC-1 and AC-2 safely."
    payload = normalize_handoff_payload(
        {
            "goal": huge,
            "success": False,
            "is_continue": True,
            "summary": huge,
            "done": [huge] * 20,
            "in_flight": huge,
            "next_step": huge,
            "discoveries": [huge] * 20,
            "blockers": [huge] * 20,
            "artifact_refs": [huge] * 20,
            "target_ac": "AC-99",
            "remaining_acs": ["AC-1", "AC-2", "AC-3"],
        },
        task=task,
        session_num=3,
        ac_ids=["AC-1", "AC-2"],
        max_bytes=2048,
    )
    ok, reason = validate_handoff_payload(payload, max_bytes=2048)
    assert ok, reason
    assert len(json.dumps(payload, ensure_ascii=True).encode("utf-8")) <= 2048
    assert payload["target_ac"] in ("AC-1", "AC-2")


