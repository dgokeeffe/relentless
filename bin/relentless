def _test_continuation_prompt_stays_compact() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        state_file = Path(temp_dir) / "_relentless_state.md"
        handoff_file = Path(temp_dir) / "_relentless_handoff.json"
        large_blob = "VERY_LARGE_PROGRESS_BLOB_" + ("A" * 6000)
        state_file.write_text(large_blob)
        write_handoff_payload(
            handoff_file,
            {
                "goal": "Ship AC-1",
                "success": False,
                "is_continue": True,
                "summary": "Prior session completed setup and tests.",
                "done": ["AC-1 scaffolded"],
                "in_flight": "Refining assertion",
                "next_step": "Finalize AC-1 test pass",
                "discoveries": ["Need deterministic seed"],
                "blockers": [],
                "artifact_refs": ["plugins/relentless/bin/relentless"],
                "target_ac": "AC-1",
                "remaining_acs": ["AC-1"],
            },
            task="Task with AC-1",
            session_num=2,
            ac_ids=["AC-1"],
            max_bytes=HANDOFF_MAX_BYTES,
        )
        prompt = build_prompt(
            task="Task with AC-1",
            state_file=state_file,
            handoff_file=handoff_file,
            session_num=2,
            is_continue=True,
            ac_ids=["AC-1"],
            max_handoff_bytes=HANDOFF_MAX_BYTES,
        )
        assert "VERY_LARGE_PROGRESS_BLOB_" not in prompt
        assert len(prompt) < 3500


def _test_system_prompt_template_render():
    """Verify template renders correctly in all modes."""
    # Base mode — no escalate, no ACs
    prompt = build_system_prompt(Path("/tmp/state.md"), Path("/tmp/handoff.json"))
    assert "State file: /tmp/state.md" in prompt
    assert "Handoff file: /tmp/handoff.json" in prompt
    assert HANDOFF_SCHEMA_VERSION in prompt
    assert "PRD MODE" not in prompt
    assert "ACCEPTANCE CRITERIA" not in prompt
    assert "{# IF" not in prompt  # no marker remnants

    # PRD mode — escalate_rules present
    prompt = build_system_prompt(
        Path("/tmp/s.md"), Path("/tmp/h.json"),
        escalate_rules="     - External API failure\n     - Budget exceeded",
    )
    assert "PRD MODE" in prompt
    assert "External API failure" in prompt
    assert "ACCEPTANCE CRITERIA" not in prompt

    # AC mode — ac_ids present, no escalate
    prompt = build_system_prompt(
        Path("/tmp/s.md"), Path("/tmp/h.json"),
        ac_ids=["AC-1", "AC-2", "AC-3"],
    )
    assert "AC-1, AC-2, AC-3" in prompt
    assert "ACCEPTANCE CRITERIA" in prompt
    assert "PRD MODE" not in prompt


def run_self_tests() -> int:
    tests = [
        ("tool_loop_detector_exempt_paths", _test_tool_loop_detector_exempt_paths),
        ("failure_signature_detector_loop", _test_failure_signature_detector_loop),
        ("failure_signature_detector_reset", _test_failure_signature_detector_reset),
        ("adaptive_tuning_profile_and_flags", _test_adaptive_tuning_profile_and_flags),
        ("handoff_normalization_enforces_size_and_schema", _test_handoff_normalization_enforces_size_and_schema),
        ("fallback_handoff_from_state", _test_fallback_handoff_from_state),
        ("continuation_prompt_stays_compact", _test_continuation_prompt_stays_compact),
        ("system_prompt_template_render", _test_system_prompt_template_render),
    ]

    failures: list[str] = []
    print("Running relentless self-tests...")
    for name, test_fn in tests:
        try:
            test_fn()
            print(f"[PASS] {name}")
        except Exception as exc:
            print(f"[FAIL] {name}: {exc}")
            failures.append(name)

    if failures:
        print(f"Self-tests failed: {', '.join(failures)}")
        return 1
    print("All self-tests passed.")
    return 0


# ── Diagnostic Snapshots ──────────────────────────────────────

def write_diagnostic(
    reason: str,
    session_num: int,
    state_file: Path,
    log_dir: Path,
    tracker: StateTracker,
    audit_trail: list[dict] | None = None,
    cost_usd: float = 0.0,
    total_cost_usd: float = 0.0,
) -> Path:
    """Preserve full context on failure for human review."""
    ts = datetime.now().strftime("%H%M%S")
    path = log_dir / f"diagnostic_s{session_num}_{ts}.json"

    state_content = state_file.read_text() if state_file.exists() else ""

    diag = {
        "reason": reason,
        "session": session_num,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "state_hash": tracker.compute_hash(),
        "state_hash_history": [{"session": s, "hash": h} for s, h in tracker.hashes],
        "state_content": state_content,
        "session_cost_usd": cost_usd,
        "total_cost_usd": total_cost_usd,
        "audit_trail": (audit_trail or [])[-50:],  # last 50 tool calls
    }

    path.write_text(json.dumps(diag, indent=2))
    log.info(f"Diagnostic snapshot written: {path}")
    return path


# ── Escalation Injection ──────────────────────────────────────

def inject_escalation(state_file: Path, reason: str, diag_path: Path):
    """Prepend ESCALATION to state file so next session / human can see it."""
    current = state_file.read_text() if state_file.exists() else ""
    if "ESCALATION" in current:
        return
    state_file.write_text(
        f"ESCALATION: {reason}\n"
        f"Diagnostic: {diag_path}\n"
        f"The agent needs human review before continuing.\n\n"
        f"{current}"
    )


# ── System Prompt ─────────────────────────────────────────────

_TEMPLATE_CACHE: str | None = None


def _load_system_prompt_template() -> str:
    """Load system_prompt.md from alongside this script; fall back to inline."""
    global _TEMPLATE_CACHE
    if _TEMPLATE_CACHE is not None:
        return _TEMPLATE_CACHE

    template_path = Path(__file__).resolve().parent / "system_prompt.md"
    if template_path.exists():
        _TEMPLATE_CACHE = template_path.read_text()
        return _TEMPLATE_CACHE

    log.warning("system_prompt.md not found beside script; using inline fallback")
    _TEMPLATE_CACHE = _INLINE_SYSTEM_PROMPT
    return _TEMPLATE_CACHE


def _render_template(template: str, variables: dict) -> str:
    """Render a system prompt template with conditional blocks and variable substitution."""
    result = template

    # Process conditional blocks: {# IF varname #}...{# ENDIF varname #}
    for var_name in ("escalate_rules", "ac_hint"):
        pattern = re.compile(
            rf"\{{# IF {var_name} #\}}.*?\{{# ENDIF {var_name} #\}}\n?",
            re.DOTALL,
        )
        if variables.get(var_name):
            # Keep block content, strip markers
            result = result.replace(f"{{# IF {var_name} #}}\n", "")
            result = result.replace(f"{{# IF {var_name} #}}", "")
            result = result.replace(f"{{# ENDIF {var_name} #}}\n", "")
            result = result.replace(f"{{# ENDIF {var_name} #}}", "")
        else:
            # Remove entire block
            result = pattern.sub("", result)

    try:
        return result.format_map(variables)
    except (KeyError, ValueError) as exc:
        log.warning(f"Template render failed ({exc}); using inline fallback")
        return _render_template(_INLINE_SYSTEM_PROMPT, variables)


# Inline fallback — kept for resilience if system_prompt.md is missing
_INLINE_SYSTEM_PROMPT = """\
You are running inside a relentless auto-continuation loop. Your session has a
CONTEXT BUDGET. When it's exhausted you will be CUT OFF and a fresh session will continue
from a compact handoff. The task/PRD is re-sent to every session, so you always have the plan.
DO NOT rely on long in-memory context across sessions.

State file: {state_file}
Handoff file: {handoff_file}

## STATE FILE FORMAT

```markdown
STATUS: IN_PROGRESS | COMPLETE | ESCALATION

## Completed
[STEP] <action> — <result> (file paths, specifics)
[STEP] <action> — <result>

## In Progress
Working on: <current step from the plan/PRD>

## Discoveries
<!-- Implementation decisions NOT in the PRD — approach changes, gotchas, constraints
     found during work. These are expensive to re-derive. -->
- Tried X, failed because Y — switched to Z
- Found that A requires B (not documented in PRD)

## Remaining
<!-- Which acceptance criteria / plan steps are not yet started -->
- AC-3: ...
- AC-4: ...

## Blockers
<!-- Anything needing human input or a different approach -->
```

## HANDOFF JSON CONTRACT (STRICT)

Write/update `{handoff_file}` at least every ~5 tool calls and before ending a session.
Keep it concise (bounded memory). Use this exact schema:

```json
{{{{
  "schema_version": "{HANDOFF_SCHEMA_VERSION}",
  "session": <int>,
  "goal": "<one-line goal>",
  "success": <bool>,
  "is_continue": <bool>,
  "summary": "<first-person chronological summary>",
  "done": ["<completed items>"],
  "in_flight": "<current item>",
  "next_step": "<next concrete action>",
  "discoveries": ["<non-obvious findings>"],
  "blockers": ["<human decisions needed>"],
  "artifact_refs": ["<paths touched>"],
  "target_ac": "<AC-id or empty>",
  "remaining_acs": ["<AC ids still open>"],
  "updated_at": "<ISO8601>"
}}}}
```

## RULES

1. WRITE BOTH FILES WITHIN YOUR FIRST 3 TOOL CALLS.
   - Session 1: initialize state and handoff.
   - Continuation: read handoff first, then state file.
   - If you haven't updated handoff in the last 5 tool calls, update it NOW.

2. DO NOT DUPLICATE THE PLAN. The task/PRD is passed to every session. The state file
   and handoff track progress against it — not a copy of it.

3. DISCOVERIES ARE CRITICAL. If you learn something during implementation that isn't
   in the PRD (approach changes, unexpected constraints, what worked/didn't), write it
   to state + handoff Discoveries. The next session needs these to avoid re-learning them.

4. UPDATE "In Progress" BEFORE starting each step — if you get cut off mid-step,
   the next session knows exactly where you were and can verify it completed.

5. STEP LOGGING: After each significant action, append to Completed:
   `[STEP] <action> — <result>`
   Include file paths and specifics. This is the audit trail.

6. SELF-LOOP DETECTION — Before each action, check Completed:
   - Same step failed 2+ times with same error → do NOT retry.
   - Try a DIFFERENT approach OR set STATUS: ESCALATION.

7. FINISH PROTOCOL:
   - On completion: set `success=true`, `is_continue=false`, and summarize what passed.
   - On continuation: set `success=false`, `is_continue=true`, with explicit `next_step`.
   - Never leave these ambiguous.

8. NEVER redo work listed in Completed.

9. CONTEXT AWARENESS:
   - After EVERY file edit or test run, update state + handoff immediately.
   - Keep handoff compact and bounded. Do not paste large logs or file dumps.

10. TOOL TIMEOUTS: Use focused tests with timeouts (pytest --timeout=10 -x,
    jest --bail --testTimeout=10000). Never run full suites.

11. HEARTBEAT: Update handoff every ~10 tool calls during long operations.

12. SESSION FOCUS: Do one micro-objective per session. Prefer single-AC progress.\
"""


def build_system_prompt(
    state_file: Path,
    handoff_file: Path,
    escalate_rules: str = "",
    ac_ids: list[str] | None = None,
) -> str:
    ac_list = ac_ids or []
    ac_hint = ", ".join(ac_list[:8]) if ac_list else ""

    template = _load_system_prompt_template()

    return _render_template(template, {
        "state_file": str(state_file),
        "handoff_file": str(handoff_file),
        "HANDOFF_SCHEMA_VERSION": HANDOFF_SCHEMA_VERSION,
        "escalate_rules": escalate_rules,
        "ac_hint": ac_hint,
    })


# ── PRD Detection ─────────────────────────────────────────────

def detect_prd_mode(task: str) -> tuple[bool, str]:
    markers = ['"agent_mode"', '"escalate_on"', "Agent Handoff"]
    if not any(m in task for m in markers):
        return False, ""

    rules = []
    in_escalate = False
    for line in task.splitlines():
        if '"escalate_on"' in line:
            in_escalate = True
            continue
        if in_escalate:
            if "]" in line:
                in_escalate = False
                continue
            stripped = line.strip().strip('",')
            if stripped:
                rules.append(f"     - {stripped}")
    return True, "\n".join(rules)


# ── Session Prompt Builder ────────────────────────────────────

def build_prompt(
    task: str,
    state_file: Path,
    handoff_file: Path,
    session_num: int,
    is_continue: bool,
    ac_ids: list[str],
    max_handoff_bytes: int,
) -> str:
    handoff_payload, _ = read_handoff_payload(handoff_file, max_handoff_bytes)
    handoff_brief = summarize_handoff_for_prompt(handoff_payload)
    target_ac = ""
    if handoff_payload and isinstance(handoff_payload.get("target_ac"), str):
        target_ac = handoff_payload.get("target_ac", "")
    if not target_ac and ac_ids:
        target_ac = ac_ids[0]

    if session_num == 1 and not is_continue:
        ac_hint = f"Start with target AC `{target_ac}`." if target_ac else ""
        return (
            f"# Task\n\n{task}\n\n"
            f"# Working directory: {os.getcwd()}\n\n"
            f"# TRACKING (mandatory)\n\n"
            f"Two tracking files exist and MUST be updated throughout this session:\n"
            f"- **State file**: `{state_file}` — append `[STEP] <action> — <result>` after EVERY significant action\n"
            f"- **Handoff JSON**: `{handoff_file}` — update `done`, `in_flight`, `next_step` after each step\n\n"
            f"Read both files now to see their format. After completing the task, "
            f"set state `STATUS: COMPLETE` and handoff `success=true, is_continue=false`.\n\n"
            f"{ac_hint}"
        )

    return (
        f"# Continue Task (Session {session_num})\n\n"
        f"## Task / PRD:\n{task}\n\n"
        f"## Prior handoff (compact):\n{handoff_brief}\n\n"
        f"## Instructions:\n"
        f"1. Read handoff JSON at `{handoff_file}` FIRST, then state file at `{state_file}`.\n"
        f"2. Verify `in_flight` completion before starting new work.\n"
        f"3. Continue from `next_step` and keep focus to one AC at a time.\n"
        f"4. Keep handoff concise (summary + next_step + target_ac + remaining_acs).\n"
        f"5. If a step failed 2+ times, change approach or escalate.\n"
        f"6. On stop, always write finish protocol in handoff:\n"
        f"   - success=true,is_continue=false when done\n"
        f"   - success=false,is_continue=true otherwise"
    )


# ── SDK Session Runner ────────────────────────────────────────

async def run_session(
    prompt: str,
    system_prompt: str,
    session_num: int,
    args: argparse.Namespace,
    state_file: Path,
    tracker: StateTracker,
    log_dir: Path,
    total_cost: float,
) -> tuple[str, float, list[dict]]:
    """Run a single SDK session. Returns (stop_reason, session_cost, audit_trail).

    stop_reason: "complete" | "incomplete" | "loop_detected" | "stall" |
                 "context_limit" | "error"
    """
    # Exempt state/handoff files from loop detection — the agent is expected
    # to write these repeatedly with similar content as part of the protocol.
    handoff_file = default_handoff_file_for_state(state_file)
    exempt = {str(state_file), str(handoff_file)}
    loop_detector = ToolLoopDetector(repeat_limit=args.tool_repeat_limit, exempt_paths=exempt)
    failure_detector = FailureSignatureDetector(repeat_limit=args.failure_repeat_limit)
    context_budget = ContextBudget(
        max_turns=args.max_turns,
        max_chars=args.context_chars,
        soft_pct=args.context_soft_pct,
        hard_pct=args.context_hard_pct,
    )
    session_cost = 0.0

    stderr_lines: list[str] = []

    def capture_stderr(line: str) -> None:
        stderr_lines.append(line)
        log.debug(f"[session {session_num}] stderr: {line.rstrip()}")

    # Build SDK options — prefer system claude CLI over bundled (may be outdated)
    system_cli = shutil.which("claude") or shutil.which("isaac")
    opts_kwargs: dict = {
        "permission_mode": args.p,
        "system_prompt": {
            "type": "preset",
            "preset": "claude_code",
            "append": system_prompt,
        },
        "cwd": os.getcwd(),
        "stderr": capture_stderr,
    }
    # bypassPermissions: grant all tools explicitly via allowed_tools
    if args.p == "bypassPermissions":
        opts_kwargs["allowed_tools"] = [
            "Read", "Write", "Edit", "Bash", "Glob", "Grep",
            "Agent", "NotebookEdit", "WebFetch", "WebSearch",
        ]
    if system_cli:
        opts_kwargs["cli_path"] = system_cli

    if args.m:
        opts_kwargs["model"] = args.m
    if args.b:
        opts_kwargs["max_budget_usd"] = float(args.b)

    options = ClaudeAgentOptions(**opts_kwargs)

    log.info(f"[session {session_num}] Starting SDK session")

    timeout_secs = args.t * 60
    session_start = time.time()
    timed_out = False

    try:
        async for message in _stream_with_detection(
            prompt=prompt,
            options=options,
            session_num=session_num,
            loop_detector=loop_detector,
            context_budget=context_budget,
            state_file=state_file,
            tracker=tracker,
            log_dir=log_dir,
            verbose=args.v,
            total_cost=total_cost,
            max_tool_calls=args.max_tool_calls,
            failure_detector=failure_detector,
        ):
            # Check timeout between messages (avoids asyncio.timeout/anyio conflict)
            if time.time() - session_start > timeout_secs:
                timed_out = True
                break

            # _stream_with_detection yields ResultMessage or loop signal
            if isinstance(message, ResultMessage):
                session_cost = message.total_cost_usd or 0.0
                is_error = message.is_error
                turns = message.num_turns
                log.info(
                    f"[session {session_num}] Finished: turns={turns} "
                    f"cost=${session_cost:.4f} error={is_error}"
                )
                if is_error:
                    return "error", session_cost, loop_detector.audit_trail
                return "complete", session_cost, loop_detector.audit_trail

            elif isinstance(message, str) and message.startswith("CONTEXT_LIMIT:"):
                status = message[14:]
                log.info(f"[session {session_num}] Context limit reached: {status}")
                return "context_limit", session_cost, loop_detector.audit_trail

            elif isinstance(message, str) and message.startswith("LOOP:"):
                reason = message[5:]
                log.error(f"[session {session_num}] Loop detected: {reason}")
                return "loop_detected", session_cost, loop_detector.audit_trail

    except Exception as exc:
        # Suppress anyio cancel-scope cleanup errors from SDK internals
        if "cancel scope" in str(exc):
            log.debug(f"[session {session_num}] Suppressed SDK cleanup error: {exc}")
        else:
            log.error(f"[session {session_num}] Error: {exc}")
            return "error", session_cost, loop_detector.audit_trail

    if timed_out:
        log.error(f"[session {session_num}] Timeout after {args.t}m")
        diag = write_diagnostic(
            reason=f"Session timeout ({args.t}m)",
            session_num=session_num,
            state_file=state_file,
            log_dir=log_dir,
            tracker=tracker,
            audit_trail=loop_detector.audit_trail,
            cost_usd=session_cost,
            total_cost_usd=total_cost + session_cost,
        )
        inject_escalation(state_file, f"Session {session_num} timed out after {args.t}m", diag)
        return "stall", session_cost, loop_detector.audit_trail

    return "incomplete", session_cost, loop_detector.audit_trail


async def _stream_with_detection(
    prompt: str,
    options: ClaudeAgentOptions,
    session_num: int,
    loop_detector: ToolLoopDetector,
    context_budget: ContextBudget,
    state_file: Path,
    tracker: StateTracker,
    log_dir: Path,
    verbose: bool,
    total_cost: float,
    max_tool_calls: int,
    failure_detector: FailureSignatureDetector,
):
    """Async generator that wraps query() with per-message loop detection.

    Yields ResultMessage on normal completion, "LOOP:<reason>" on loop,
    or "CONTEXT_LIMIT:<status>" when context budget is exhausted.
    """
    last_message_time = time.time()

    async for message in query(prompt=prompt, options=options):
        last_message_time = time.time()

        # ── Track context budget on every message ──
        context_budget.record_message(message)

        if context_budget.should_warn():
            log.warning(
                f"[session {session_num}] Context budget at {context_budget.utilization:.0%} — "
                f"{context_budget.status()}"
            )

        if isinstance(message, AssistantMessage):
            # ── Check hard context limit BETWEEN turns (not mid-tool-call) ──
            if context_budget.should_stop():
                log.warning(
                    f"[session {session_num}] Context budget exceeded — "
                    f"graceful handoff: {context_budget.status()}"
                )
                yield f"CONTEXT_LIMIT:{context_budget.status()}"
                return

            for block in message.content:
                if isinstance(block, ToolUseBlock):
                    tool_name = block.name
                    tool_input = block.input

                    if verbose:
                        input_preview = json.dumps(tool_input, default=str)[:120]
                        log.info(f"  [{loop_detector.total_calls + 1}] {tool_name}: {input_preview}")

                    # ── Intra-session loop detection ──
                    is_loop, loop_desc = loop_detector.record(tool_name, tool_input)
                    if is_loop:
                        log.error(f"[session {session_num}] Tool loop: {loop_desc}")
                        diag = write_diagnostic(
                            reason=f"Intra-session tool loop: {loop_desc}",
                            session_num=session_num,
                            state_file=state_file,
                            log_dir=log_dir,
                            tracker=tracker,
                            audit_trail=loop_detector.audit_trail,
                            total_cost_usd=total_cost,
                        )
                        inject_escalation(state_file, f"Tool loop in session {session_num}: {loop_desc}", diag)
                        yield f"LOOP:{loop_desc}"
                        return

                    # ── Safety cap ──
                    if loop_detector.total_calls >= max_tool_calls:
                        log.warning(f"[session {session_num}] Hit {max_tool_calls} tool call cap")
                        yield f"LOOP:Safety cap — {max_tool_calls} tool calls in one session"
                        return

                elif isinstance(block, TextBlock) and verbose:
                    text_preview = block.text[:200].replace("\n", " ")
                    if text_preview.strip():
                        log.info(f"  [text] {text_preview}")

        elif isinstance(message, ResultMessage):
            yield message
            return

        elif isinstance(message, UserMessage):
            # Tool results can blow up the context — check budget after recording
            if context_budget.should_stop():
                log.warning(
                    f"[session {session_num}] Context budget exceeded after tool result — "
                    f"graceful handoff: {context_budget.status()}"
                )
                yield f"CONTEXT_LIMIT:{context_budget.status()}"
                return
            tool_result_text = str(message.content)
            repeated_failure, failure_desc = failure_detector.record(tool_result_text)
            if repeated_failure:
                log.error(f"[session {session_num}] Repeated failure signature: {failure_desc}")
                diag = write_diagnostic(
                    reason=f"Repeated failure signature: {failure_desc}",
                    session_num=session_num,
                    state_file=state_file,
                    log_dir=log_dir,
                    tracker=tracker,
                    audit_trail=loop_detector.audit_trail,
                    total_cost_usd=total_cost,
                )
                inject_escalation(
                    state_file,
                    f"Repeated failure loop in session {session_num}: {failure_desc}",
                    diag,
                )
                yield f"LOOP:{failure_desc}"
                return
            if verbose:
                log.debug(f"  [user msg] (tool result or system)")


# ── Checkpoint Micro-Session ─────────────────────────────────

async def run_checkpoint_session(
    state_file: Path,
    handoff_file: Path,
    task: str,
    audit_trail: list[dict],
    args: argparse.Namespace,
    session_num: int,
    reason: str,
    ac_ids: list[str],
) -> float:
    """Spawn a brief session to finalize state + handoff after interruption.

    This micro-session gets a fresh context with enough info to update BOTH files:
    - The original task (so it knows the goal)
    - The last N tool calls from the audit trail (so it knows recent progress)
    - Instruction to read state + handoff, update finish protocol, and stop
    """
    # Summarize recent tool calls for the checkpoint agent
    recent = audit_trail[-10:] if audit_trail else []
    recent_summary = "\n".join(
        f"  {i+1}. {entry['tool']}" for i, entry in enumerate(recent)
    )

    checkpoint_prompt = (
        f"CHECKPOINT MICRO-SESSION ({reason}).\n\n"
        f"Session #{session_num} interrupted. Last tool calls before interruption:\n"
        f"{recent_summary or '  (no tool calls recorded)'}\n\n"
        f"Read state file `{state_file}` and handoff file `{handoff_file}` and update BOTH:\n"
        f"- If 'In Progress' step looks complete based on the tool calls above, move it "
        f"to Completed.\n"
        f"- Add: '[HANDOFF] Session {session_num} ended — {reason}'\n"
        f"- Preserve Discoveries section — the next session needs those.\n"
        f"- Write compact JSON handoff with schema_version='{HANDOFF_SCHEMA_VERSION}', "
        f"success/is_continue/summary/next_step/target_ac/remaining_acs.\n"
        f"- Do NOT continue implementing. Only checkpoint and stop.\n"
    )

    system_cli = shutil.which("claude") or shutil.which("isaac")
    opts_kwargs: dict = {
        "permission_mode": args.p,
        "cwd": os.getcwd(),
        "max_budget_usd": 0.50,  # cap checkpoint cost
    }
    if system_cli:
        opts_kwargs["cli_path"] = system_cli
    if args.m:
        opts_kwargs["model"] = args.m
    options = ClaudeAgentOptions(**opts_kwargs)

    log.info(f"[checkpoint] Spawning micro-session to finalize state file")
    cost = 0.0

    async def _run():
        nonlocal cost
        async for msg in query(prompt=checkpoint_prompt, options=options):
            if isinstance(msg, ResultMessage):
                cost = msg.total_cost_usd or 0.0

    try:
        await asyncio.wait_for(_run(), timeout=120)
        log.info(f"[checkpoint] Done (${cost:.4f})")
    except asyncio.TimeoutError:
        log.warning("[checkpoint] Timed out after 120s")
    except Exception as e:
        log.warning(f"[checkpoint] Failed: {e}")

    # If the checkpoint did not leave a valid handoff, generate deterministic fallback
    payload, _ = read_handoff_payload(handoff_file, args.handoff_max_bytes)
    if payload is None:
        fallback_handoff_from_state(
            task=task,
            state_file=state_file,
            handoff_file=handoff_file,
            session_num=session_num,
            ac_ids=ac_ids,
            max_bytes=args.handoff_max_bytes,
            reason=f"checkpoint fallback ({reason})",
        )
    return cost


async def ensure_handoff_after_session(
    *,
    state_file: Path,
    handoff_file: Path,
    task: str,
    audit_trail: list[dict],
    args: argparse.Namespace,
    session_num: int,
    stop_reason: str,
    ac_ids: list[str],
) -> tuple[dict, float]:
    payload, reason = read_handoff_payload(handoff_file, args.handoff_max_bytes)
    if payload is not None:
        normalized = write_handoff_payload(
            handoff_file,
            payload,
            task=task,
            session_num=session_num,
            ac_ids=ac_ids,
            max_bytes=args.handoff_max_bytes,
        )
        return normalized, 0.0

    log.warning(f"[session {session_num}] Invalid/missing handoff: {reason}")
    cp_cost = 0.0
    if not args.no_checkpoint:
        cp_cost = await run_checkpoint_session(
            state_file=state_file,
            handoff_file=handoff_file,
            task=task,
            audit_trail=audit_trail,
            args=args,
            session_num=session_num,
            reason=f"handoff-repair:{stop_reason}",
            ac_ids=ac_ids,
        )
        payload, reason = read_handoff_payload(handoff_file, args.handoff_max_bytes)
        if payload is not None:
            normalized = write_handoff_payload(
                handoff_file,
                payload,
                task=task,
                session_num=session_num,
                ac_ids=ac_ids,
                max_bytes=args.handoff_max_bytes,
            )
            return normalized, cp_cost

    fallback = fallback_handoff_from_state(
        task=task,
        state_file=state_file,
        handoff_file=handoff_file,
        session_num=session_num,
        ac_ids=ac_ids,
        max_bytes=args.handoff_max_bytes,
        reason=f"fallback:{stop_reason}:{reason}",
    )
    return fallback, cp_cost


# ── Main ──────────────────────────────────────────────────────

def _suppress_anyio_cleanup(loop, context):
    """Suppress known anyio cancel-scope cleanup errors from Claude Agent SDK."""
    exc = context.get("exception")
    if exc and "cancel scope" in str(exc):
        return  # Swallow — this is a known SDK cleanup race condition
    loop.default_exception_handler(context)


async def async_main():
    # Suppress noisy anyio cancel-scope errors from SDK generator cleanup
    asyncio.get_event_loop().set_exception_handler(_suppress_anyio_cleanup)

    parser = argparse.ArgumentParser(
        description="relentless — auto-continuing Claude Code agent (SDK)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("task", nargs="*", help="Task description")
    parser.add_argument("-n", type=int, default=5, metavar="NUM", help="Max sessions (default: 5)")
    parser.add_argument("-b", type=str, default="", metavar="USD", help="Max budget per session in USD")
    parser.add_argument("-m", type=str, default="", metavar="MODEL", help="Model to use")
    parser.add_argument("-d", type=str, default=".", metavar="DIR", help="Working directory")
    parser.add_argument("-f", type=str, default="", metavar="FILE", help="Read task from file")
    parser.add_argument("-p", type=str, default="auto", metavar="MODE", help="Permission mode (default: auto)")
    parser.add_argument("-s", type=str, default="./_relentless_state.md", metavar="FILE", help="State file path")
    parser.add_argument(
        "--handoff-file",
        type=str,
        default="",
        metavar="FILE",
        help="Handoff JSON path (default: alongside state file)",
    )
    parser.add_argument("-t", type=int, default=30, metavar="MINS", help="Session timeout in minutes (default: 30)")
    parser.add_argument("-v", action="store_true", help="Verbose output")
    parser.add_argument("-c", action="store_true", help="Continue from existing state file")
    parser.add_argument("--dry-run", action="store_true", help="Print prompt without running")
    parser.add_argument(
        "--max-turns", type=int, default=DEFAULT_MAX_TURNS, metavar="N",
        help=f"Max assistant turns per session before handoff (default: {DEFAULT_MAX_TURNS})",
    )
    parser.add_argument(
        "--context-chars", type=int, default=DEFAULT_CONTEXT_CHARS, metavar="N",
        help=f"Estimated char budget per session (default: {DEFAULT_CONTEXT_CHARS:,})",
    )
    parser.add_argument(
        "--no-checkpoint", action="store_true",
        help="Skip checkpoint micro-session on context handoff",
    )
    parser.add_argument(
        "--stuck-threshold", type=int, default=STUCK_THRESHOLD, metavar="N",
        help=f"Escalate after N sessions with identical state hash (default: {STUCK_THRESHOLD})",
    )
    parser.add_argument(
        "--tool-repeat-limit", type=int, default=TOOL_REPEAT_LIMIT, metavar="N",
        help=f"Same tool+input N times in one session → loop (default: {TOOL_REPEAT_LIMIT})",
    )
    parser.add_argument(
        "--max-tool-calls", type=int, default=MAX_TOOL_CALLS_PER_SESSION, metavar="N",
        help=f"Safety cap on tool calls per session (default: {MAX_TOOL_CALLS_PER_SESSION})",
    )
    parser.add_argument(
        "--failure-repeat-limit", type=int, default=FAILURE_REPEAT_LIMIT, metavar="N",
        help=f"Same failing tool-result signature N times in one session → loop (default: {FAILURE_REPEAT_LIMIT})",
    )
    parser.add_argument(
        "--context-soft-pct", type=float, default=CONTEXT_SOFT_PCT, metavar="F",
        help=f"Context utilization fraction to warn (default: {CONTEXT_SOFT_PCT})",
    )
    parser.add_argument(
        "--context-hard-pct", type=float, default=CONTEXT_HARD_PCT, metavar="F",
        help=f"Context utilization fraction to force handoff (default: {CONTEXT_HARD_PCT})",
    )
    parser.add_argument(
        "--handoff-max-bytes",
        type=int,
        default=HANDOFF_MAX_BYTES,
        metavar="N",
        help=f"Max serialized handoff JSON bytes (default: {HANDOFF_MAX_BYTES})",
    )
    parser.add_argument(
        "--adaptive",
        dest="adaptive",
        action="store_true",
        default=True,
        help="Enable adaptive tuning from prior relentless runs (default: on)",
    )
    parser.add_argument(
        "--no-adaptive",
        dest="adaptive",
        action="store_false",
        help="Disable adaptive tuning from prior relentless runs",
    )
    parser.add_argument(
        "--adaptive-profile",
        choices=("conservative", "balanced", "aggressive"),
        default=ADAPTIVE_PROFILE_DEFAULT,
        help="Adaptive tuning profile (default: balanced)",
    )
    parser.add_argument(
        "--self-test",
        action="store_true",
        help="Run internal detectors/tuning self-tests and exit",
    )
    args = parser.parse_args()
    cli_args = sys.argv[1:]

    if args.self_test:
        sys.exit(run_self_tests())

    # ── Resolve task ──
    if args.f:
        task = Path(args.f).read_text()
    elif args.task:
        task = " ".join(args.task)
    elif not sys.stdin.isatty():
        task = sys.stdin.read()
    else:
        print("Error: No task provided. Pass as argument, -f file, or pipe via stdin.", file=sys.stderr)
        sys.exit(1)

    # ── Setup ──
    os.chdir(args.d)
    state_file = Path(os.path.abspath(args.s))
    handoff_file = (
        Path(os.path.abspath(args.handoff_file))
        if args.handoff_file
        else default_handoff_file_for_state(state_file)
    )
    log_dir = Path(os.getcwd()) / ".relentless_logs"

    master_log = setup_logging(log_dir, args.v)
    tracker = StateTracker(state_file, stuck_threshold=args.stuck_threshold)
    task_hash = compute_task_hash(task)
    adaptive_notes: list[str] = []
    if args.adaptive:
        adaptive_notes = apply_adaptive_overrides(
            args=args,
            log_dir=log_dir,
            task_hash=task_hash,
            cli_args=cli_args,
            profile=args.adaptive_profile,
        )

    # PRD detection
    is_prd, escalate_rules = detect_prd_mode(task)
    ac_ids = extract_acceptance_criteria(task) if is_prd else []
    system_prompt = build_system_prompt(
        state_file=state_file,
        handoff_file=handoff_file,
        escalate_rules=escalate_rules,
        ac_ids=ac_ids,
    )

    # Bootstrap handoff if possible so continuation starts from a compact protocol object
    existing_handoff, _ = read_handoff_payload(handoff_file, args.handoff_max_bytes)
    if existing_handoff is None and state_file.exists():
        fallback_handoff_from_state(
            task=task,
            state_file=state_file,
            handoff_file=handoff_file,
            session_num=0,
            ac_ids=ac_ids,
            max_bytes=args.handoff_max_bytes,
            reason="startup bootstrap",
        )

    # Strip Claude env vars so nested SDK sessions work
    os.environ.pop("CLAUDECODE", None)
    os.environ.pop("CLAUDE_CODE_ENTRYPOINT", None)

    # ── Verify Claude CLI is available ──
    cli_path = shutil.which("claude") or shutil.which("isaac")
    if not cli_path:
        print(
            "Error: Claude Code CLI not found on PATH.\n"
            "Install it: https://docs.anthropic.com/en/docs/claude-code\n"
            "Then verify: claude --version",
            file=sys.stderr,
        )
        sys.exit(1)

    # ── Banner ──
    print("╔══════════════════════════════════════════════╗")
    print("║  relentless — Claude Agent SDK engine         ║")
    print("╠══════════════════════════════════════════════╣")
    print(f"║  Sessions:      max {args.n}")
    print(f"║  Model:         {args.m or 'default'}")
    print(f"║  Budget:        {args.b or 'unlimited'}/session")
    print(f"║  Perms:         {args.p}")
    print(f"║  State:         {state_file}")
    print(f"║  Handoff:       {handoff_file} ({args.handoff_max_bytes} bytes cap)")
    print(f"║  Timeout:       {args.t}m/session")
    print(f"║  Loop guard:    tool repeat ≥{args.tool_repeat_limit}x → escalate")
    print(f"║  Fail signature:{args.failure_repeat_limit} repeated failures → escalate")
    print(f"║  Cross-session: {args.stuck_threshold} identical states → escalate")
    print(f"║  Context:       {args.max_turns} turns / {args.context_chars:,} chars → handoff")
    print(
        f"║  Adaptive:      {'on' if args.adaptive else 'off'} "
        f"({args.adaptive_profile})"
    )
    if args.adaptive and adaptive_notes:
        print("║  Adaptive notes:")
        for note in adaptive_notes[:3]:
            print(f"║    - {note}")
    print(f"║  Checkpoint:    {'off' if args.no_checkpoint else 'on (micro-session)'}")
    print(f"║  Logs:          {log_dir}/")
    if is_prd:
        print("║  Mode:          PRD (acceptance criteria enforced)")
    print("╚══════════════════════════════════════════════╝")
    print()

    total_start = time.time()
    total_cost = 0.0
    stop_reason_counts: dict[str, int] = {}

    def finalize_run(exit_code: int, final_reason: str, sessions_used: int) -> None:
        elapsed_now = int(time.time() - total_start)
        if not args.dry_run:
            append_run_history(
                log_dir,
                {
                    "timestamp": datetime.now(timezone.utc).isoformat(),
                    "task_hash": task_hash,
                    "exit_code": exit_code,
                    "final_reason": final_reason,
                    "sessions_used": sessions_used,
                    "elapsed_seconds": elapsed_now,
                    "total_cost_usd": round(total_cost, 6),
                    "model": args.m or "default",
                    "stop_reason_counts": stop_reason_counts,
                    "adaptive_enabled": args.adaptive,
                    "adaptive_profile": args.adaptive_profile,
                    "adaptive_notes": adaptive_notes,
                    "state_file": str(state_file),
                    "handoff_file": str(handoff_file),
                },
            )
            if exit_code == 0 and args.m:
                save_last_success_model(log_dir, args.m)
        sys.exit(exit_code)

    # ── Pre-seed state + handoff so the agent sees them from tool call 1 ──
    if not state_file.exists():
        ac_remaining = "\n".join(f"- {ac}" for ac in ac_ids) if ac_ids else "- (see task description)"
        state_file.write_text(
            f"STATUS: IN_PROGRESS\n\n"
            f"## Completed\n\n"
            f"## In Progress\nWorking on: initializing\n\n"
            f"## Discoveries\n\n"
            f"## Remaining\n{ac_remaining}\n\n"
            f"## Blockers\n"
        )
    if not handoff_file.exists():
        handoff_file.write_text(json.dumps({
            "schema_version": HANDOFF_SCHEMA_VERSION,
            "session": 0,
            "goal": "",
            "success": False,
            "is_continue": False,
            "summary": "pre-seeded by relentless engine",
            "done": [],
            "in_flight": "",
            "next_step": "begin task",
            "discoveries": [],
            "blockers": [],
            "artifact_refs": [],
            "target_ac": ac_ids[0] if ac_ids else "",
            "remaining_acs": ac_ids or [],
            "updated_at": datetime.now(timezone.utc).isoformat(),
        }, indent=2))

    for session_num in range(1, args.n + 1):
        print(f"━━━ Session {session_num}/{args.n} ━━━")

        prompt = build_prompt(
            task=task,
            state_file=state_file,
            handoff_file=handoff_file,
            session_num=session_num,
            is_continue=args.c,
            ac_ids=ac_ids,
            max_handoff_bytes=args.handoff_max_bytes,
        )

        if args.dry_run:
            print("[DRY RUN] Would send prompt:")
            print("---")
            print(prompt)
            print("---")
            print(f"\n[DRY RUN] System prompt ({len(system_prompt)} chars):")
            print(system_prompt[:500] + "..." if len(system_prompt) > 500 else system_prompt)
            finalize_run(0, "dry_run", 0)

        # ── Run session via SDK ──
        stop_reason, session_cost, audit_trail = await run_session(
            prompt=prompt,
            system_prompt=system_prompt,
            session_num=session_num,
            args=args,
            state_file=state_file,
            tracker=tracker,
            log_dir=log_dir,
            total_cost=total_cost,
        )
        stop_reason_counts[stop_reason] = stop_reason_counts.get(stop_reason, 0) + 1

        total_cost += session_cost
        elapsed = int(time.time() - total_start)
        print(f"  Session cost: ${session_cost:.4f} | Total: ${total_cost:.4f} | Elapsed: {elapsed}s")

        checkpoint_cost = 0.0

        # ── Handle context budget handoff ──
        if stop_reason == "context_limit":
            print("  ⚡ Context budget reached — graceful handoff")
            if not args.no_checkpoint:
                print("  ↳ Running checkpoint micro-session...")
                checkpoint_cost = await run_checkpoint_session(
                    state_file=state_file,
                    handoff_file=handoff_file,
                    task=task,
                    audit_trail=audit_trail,
                    args=args,
                    session_num=session_num,
                    reason="context_limit",
                    ac_ids=ac_ids,
                )
                total_cost += checkpoint_cost
                if checkpoint_cost > 0:
                    print(f"    Checkpoint cost: ${checkpoint_cost:.4f}")

        # Validate/repair handoff after every session (unified recovery path)
        session_handoff, repair_cost = await ensure_handoff_after_session(
            state_file=state_file,
            handoff_file=handoff_file,
            task=task,
            audit_trail=audit_trail,
            args=args,
            session_num=session_num,
            stop_reason=stop_reason,
            ac_ids=ac_ids,
        )
        if repair_cost > 0:
            total_cost += repair_cost
            print(f"  Handoff repair checkpoint cost: ${repair_cost:.4f}")

        append_run_journal(
            log_dir,
            {
                "timestamp": datetime.now(timezone.utc).isoformat(),
                "task_hash": task_hash,
                "session": session_num,
                "stop_reason": stop_reason,
                "session_cost_usd": round(session_cost, 6),
                "checkpoint_cost_usd": round(checkpoint_cost + repair_cost, 6),
                "total_cost_usd": round(total_cost, 6),
                "audit_tool_calls": len(audit_trail),
                "handoff": {
                    "success": bool(session_handoff.get("success")),
                    "is_continue": bool(session_handoff.get("is_continue")),
                    "target_ac": session_handoff.get("target_ac", ""),
                    "next_step": session_handoff.get("next_step", ""),
                    "summary": session_handoff.get("summary", ""),
                    "remaining_acs": session_handoff.get("remaining_acs", []),
                },
            },
        )

        if stop_reason == "context_limit":

            tracker.record(session_num)
            if session_num < args.n:
                print(f"  Continuing to session {session_num + 1} with fresh context...\n")
            continue

        # ── Handle loop detection (intra-session) ──
        if stop_reason == "loop_detected":
            diag = write_diagnostic(
                reason=f"Intra-session loop in session {session_num}",
                session_num=session_num,
                state_file=state_file,
                log_dir=log_dir,
                tracker=tracker,
                audit_trail=audit_trail,
                cost_usd=session_cost,
                total_cost_usd=total_cost,
            )
            print(f"\n⚠ Tool loop detected in session {session_num}")
            print(f"  Diagnostic: {diag}")
            # Don't exit — continue to next session which may take a different approach
            tracker.record(session_num)

            stuck, stuck_msg = tracker.is_stuck()
            if stuck:
                inject_escalation(state_file, f"Agent stuck — {stuck_msg}", diag)
                print(f"  Cross-session loop also detected: {stuck_msg}")
                print(f"\n━━━ State at pause ━━━")
                if state_file.exists():
                    print(state_file.read_text())
                finalize_run(2, "cross_session_loop_after_tool_loop", session_num)

            if session_num < args.n:
                print(f"  Continuing to session {session_num + 1} (will try different approach)...\n")
            continue

        # ── Record state hash (cross-session loop guard) ──
        tracker.record(session_num)

        # ── Check completion ──
        handoff_success = bool(session_handoff.get("success"))
        handoff_summary = str(session_handoff.get("summary", "")).strip()
        state_complete = False
        if state_file.exists():
            content = state_file.read_text()
            first_line = content.splitlines()[0] if content.strip() else ""
            state_complete = "STATUS: COMPLETE" in first_line.upper()

            if handoff_success or state_complete:
                print(f"\n✓ Task completed in session {session_num} ({elapsed}s, ${total_cost:.4f})\n")
                if handoff_summary:
                    print(f"Finish summary: {handoff_summary}")
                print("━━━ Final state ━━━")
                print(content)
                finalize_run(0, "success", session_num)
        elif handoff_success:
            print(f"\n✓ Task completed in session {session_num} ({elapsed}s, ${total_cost:.4f})\n")
            if handoff_summary:
                print(f"Finish summary: {handoff_summary}")
            finalize_run(0, "success_via_handoff", session_num)

        # ── Check escalation ──
        if state_file.exists() and "ESCALATION" in state_file.read_text().upper():
            print(f"\n⚠ Escalation detected in session {session_num} ({elapsed}s, ${total_cost:.4f})\n")
            print("━━━ State with escalation ━━━")
            print(state_file.read_text())
            print("\nReview the escalation above and decide how to proceed.")
            finalize_run(2, "escalation_state", session_num)

        # ── Check cross-session state hash loop ──
        stuck, stuck_msg = tracker.is_stuck()
        if stuck:
            log.error(f"Loop detected: {stuck_msg}")
            diag = write_diagnostic(
                reason=f"State loop: {stuck_msg}",
                session_num=session_num,
                state_file=state_file,
                log_dir=log_dir,
                tracker=tracker,
                audit_trail=audit_trail,
                cost_usd=session_cost,
                total_cost_usd=total_cost,
            )
            inject_escalation(state_file, f"Agent stuck — {stuck_msg}", diag)
            print(f"\n⚠ Agent stuck — loop detected after session {session_num} ({elapsed}s)")
            print(f"  {stuck_msg}")
            print(f"  Diagnostic: {diag}\n")
            print("━━━ State at pause ━━━")
            if state_file.exists():
                print(state_file.read_text())
            finalize_run(2, "cross_session_state_loop", session_num)

        # ── Handle stall/error ──
        if stop_reason in ("stall", "error"):
            if session_num >= args.n:
                break  # let max-sessions handler deal with it
            print(f"  Session ended with {stop_reason} — continuing to session {session_num + 1}...\n")
            continue

        if session_num < args.n:
            print(f"  Task incomplete — continuing to session {session_num + 1}...\n")

    # ── Max sessions exhausted ──
    elapsed = int(time.time() - total_start)
    print(f"\n✗ Task incomplete after {args.n} sessions ({elapsed}s, ${total_cost:.4f})\n")
    if state_file.exists():
        print("━━━ Progress so far ━━━")
        print(state_file.read_text())

    write_diagnostic(
        reason=f"Max sessions ({args.n}) exceeded without completion",
        session_num=args.n,
        state_file=state_file,
        log_dir=log_dir,
        tracker=tracker,
        cost_usd=0.0,
        total_cost_usd=total_cost,
    )
    print(f"\nSession logs saved in: {log_dir}/")
    finalize_run(1, "max_sessions_exhausted", args.n)


def main():
    asyncio.run(async_main())


if __name__ == "__main__":
    main()
